{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Mount Proton Datafiles",
            "type": "shell",
            "command": "mkdir -p ~/mnt/proton-data && rclone mount 'proton:Multidevice Datafiles' ~/mnt/proton-data --no-traverse --dir-cache-time 0 --vfs-cache-mode off",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "never", 
                "panel": "dedicated"
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "Unmount Proton Datafiles",
            "type": "shell",
            "command": "fusermount -u ~/mnt/proton-data 2>/dev/null || umount ~/mnt/proton-data 2>/dev/null || echo \"Not mounted\"",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always"
            }
        }
    ]
}